#!/bin/sh
# scripts/hooks/pre-commit
#
# Checks that every staged .cloomc file that uses dot-notation operands has a
# capabilities { } block.  Runs only when at least one .cloomc file is staged,
# so it adds no overhead to unrelated commits.
#
# Install once:
#   npm run install-hooks
# Or manually:
#   cp scripts/hooks/pre-commit .git/hooks/pre-commit
#   chmod +x .git/hooks/pre-commit

STAGED=$(git diff --cached --name-only --diff-filter=ACM | grep '\.cloomc$')

if [ -z "$STAGED" ]; then
    exit 0
fi

echo "check-capabilities: scanning staged .cloomc files..."

node scripts/check-capabilities-blocks.js --glob '**/*.cloomc'
STATUS=$?

if [ $STATUS -ne 0 ]; then
    echo ""
    echo "Commit blocked: one or more .cloomc files are missing a capabilities block."
    echo "Add the missing block(s) and re-stage the file(s), or run:"
    echo "  npm run check:capabilities"
    echo "to see the full report."
    exit 1
fi

exit 0
